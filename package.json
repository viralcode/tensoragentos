{
    "name": "tensoragent-os",
    "version": "0.2.0",
    "description": "TensorAgent OS — AI-Native Operating System powered by OpenWhale",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node packages/openwhale/openwhale.mjs",
        "build:shell": "cd packages/whaleos && bash build.sh",
        "build:iso": "bash scripts/build-iso.sh",
        "build:iso:arm64": "bash scripts/build-iso.sh --arch=aarch64",
        "setup:vm": "bash vm/setup.sh",
        "test:qemu": "bash scripts/run-qemu.sh",
        "lint": "eslint packages/*/src/**/*.{js,jsx,ts}"
    },
    "workspaces": [
        "packages/openwhale"
    ],
    "author": "Jijo John",
    "license": "MIT"
}